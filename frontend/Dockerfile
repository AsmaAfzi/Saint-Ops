# Stage 1 - Build React app
FROM node:20-alpine AS build

WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# Stage 2 - Serve with Nginx
FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html

# Fix CORS for API calls to backend
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80